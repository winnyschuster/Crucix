    "node": ">=22",
    "npm": ">=10"
  },
  "dependencies": {
    "express": "^5.1.0"
  },
  "optionalDependencies": {
    "discord.js": "^14.25.1"  },
  "overrides": {
    "undici": "^7.24.4"  }
