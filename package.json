    "brief:save": "node apis/save-briefing.mjs",
    "diag": "node diag.mjs",
    "clean": "node scripts/clean.mjs",
    "fresh-start": "npm run clean && npm start"
  },
  "keywords": [
    "osint",
    "intelligence",
    "dashboard",
    "geopolitical"
  ],
